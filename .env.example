# ─── Exchange credentials ────────────────────────────────────────
EXCHANGE_ID=binance          # binance, bybit, okx, kraken, bitget, etc.
EXCHANGE_API_KEY=YOUR_API_KEY_HERE
EXCHANGE_API_SECRET=YOUR_API_SECRET_HERE
EXCHANGE_PASSWORD=            # Only needed for exchanges that require a passphrase (OKX, KuCoin)
EXCHANGE_SANDBOX=false        # Set to true for testnet/sandbox mode

# ─── Trading defaults ────────────────────────────────────────────
DEFAULT_SYMBOL=BTC/USDT
DEFAULT_POSITION_SIZE=10.0
QUOTE_CURRENCY=USDT

# ─── Optional: Additional accounts for parallel bots ────────────
# EXCHANGE_API_KEY_2=...
# EXCHANGE_API_SECRET_2=...
# EXCHANGE_ID_2=bybit

# ─── Risk settings (override config/settings.py defaults) ───────
# MAX_POSITION_SIZE=100
# MAX_DAILY_LOSS=50
# MAX_DRAWDOWN_PCT=20

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
